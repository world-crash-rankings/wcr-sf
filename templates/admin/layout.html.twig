{% extends 'base.html.twig' %}

{% block title %}Admin - {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="{{ asset('admin.js') }}" type="module"></script>
{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand">Admin Panel</span>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_news' %}active{% endif %}"
                           href="{{ path('admin_news_list') }}">
                            News
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_player' %}active{% endif %}"
                           href="{{ path('admin_player_list') }}">
                            Players
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_zone' %}active{% endif %}"
                           href="{{ path('admin_zone_list') }}">
                            Zones
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_strat' %}active{% endif %}"
                           href="{{ path('admin_strat_list') }}">
                            Strats
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_country' %}active{% endif %}"
                           href="{{ path('admin_country_list') }}">
                            Countries
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_score' %}active{% endif %}"
                           href="{{ path('admin_score_list') }}">
                            Scores
                        </a>
                    </li>
                    {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_user' %}active{% endif %}"
                               href="{{ path('admin_user_list') }}">
                                Users
                            </a>
                        </li>
                    {% endif %}
                    {# Add more admin sections here #}
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        {% block admin_content %}{% endblock %}
    </div>
{% endblock %}
